# All variables are OPTIONAL. Aegis runs fully offline with rule/heuristic
# detection only when none of these are set.

# Optional free-tier LLM second-opinion layer (Phase 6). Leave unset to run
# rules-only. Supported providers: "groq" (default) or "gemini".
LLM_API_KEY=
LLM_PROVIDER=groq

# Defaults to a local SQLite file if unset.
DB_URL=sqlite:///./aegis.db

# Verdict thresholds (0-1). Defaults shown.
AEGIS_BLOCK_THRESHOLD=0.7
AEGIS_FLAG_THRESHOLD=0.4
